  animation:cfetti 1.5s ease-out forwards;
}
@keyframes cfetti {
  0%   { transform:translate(0,0) rotate(0deg) scale(1); opacity:1; }
  100% { transform:translate(var(--tx),var(--ty)) rotate(720deg) scale(.2); opacity:0; }
