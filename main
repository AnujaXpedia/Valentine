<body>

<div class="bg-hearts" id="bgHearts"></div>

<div class="card" id="card">
  <!-- Question -->
  <div id="questionView">
    <span id="mainEmoji">💝</span>
    <h1 id="mainTitle">Will you be <em>my Valentine?</em></h1>
    <p id="mainSub">I promise it'll be the best decision ever ✨</p>
    <div id="pleadingEmojis">🥺</div>
    <button id="yes-btn" onclick="sayYes()">Yes 💖</button>
  </div>

  <!-- Yay -->
  <div id="yayScreen">
    <div class="yay-emoji">🥳</div>
    <h2>Yayyy!! 💕</h2>
    <p>I knew you'd say yes, my love! 🌹<br>You just made me the happiest person ever!</p>
    <div class="final-emojis">💑✨🎉💕🌹</div>
  </div>
</div>

<!-- No button outside card so it can roam the full screen -->
<button id="no-btn" onclick="runNo()">No 🙃</button>

<script>
// ── Floating background hearts ──
const bgEmojis = ['🩷','💗','💓','💞','💕','🌸','✨','🫶','💘','💝'];
const bgEl = document.getElementById('bgHearts');
for (let i = 0; i < 26; i++) {
  const s = document.createElement('span');
  s.classList.add('bh');
  s.textContent = bgEmojis[Math.floor(Math.random() * bgEmojis.length)];
  s.style.left = (Math.random() * 100) + 'vw';
  s.style.fontSize = (.8 + Math.random() * 1.4) + 'rem';
  const dur = 7 + Math.random() * 10;
  s.style.animationDuration = dur + 's';
  s.style.animationDelay   = -(Math.random() * dur) + 's';
  bgEl.appendChild(s);
}

// ── Initial position of no-btn: below the yes button ──
const noBtn  = document.getElementById('no-btn');
const yesBtn = document.getElementById('yes-btn');

function positionNoBtnStart() {
  const card = document.getElementById('card');
  const r    = card.getBoundingClientRect();
  noBtn.style.left = (r.left + r.width / 2 - noBtn.offsetWidth / 2) + 'px';
  noBtn.style.top  = (r.bottom - 55) + 'px';
}

window.addEventListener('load', () => { setTimeout(positionNoBtnStart, 50); });
window.addEventListener('resize', positionNoBtnStart);

// ── Data ──
let noCount = 0;
const MAX = 8;

const yesSizes = [1.3, 1.65, 2.0,  2.4,  2.85, 3.3,  3.85, 4.4,  5.0 ];
const noSizes  = [1.0, 0.84, 0.70, 0.58, 0.47, 0.38, 0.30, 0.23, 0.17];
const noPads   = [11,  9,    7.5,  6,    5,    4,    3,    2.5,  2   ];

const pleadingSets = [
  '🥺',
  '🥺🥺',
  '🥺🥺🙏',
  '😭🥺🙏🥺😭',
  '😭😭🙏💔🥺😭',
  '💔😭🙏🥺🙏😭💔',
  '😭💔🫶🙏🥺🙏🫶💔😭',
  '💔😭😭🫶🙏🥺🙏🫶😭😭💔',
  '💔💔😭😭🫶🙏🥺🙏🫶😭😭💔💔'
];

const titles = [
  'Will you be <em>my Valentine?</em>',
  'Are you sure? 🥺 <em>Please reconsider...</em>',
  'Nooo don\'t do this! 😭 <em>I need you!</em>',
  'Come onnnn 🙏 <em>Just say yes!</em>',
  'My heart is breaking... 💔 <em>One more chance?</em>',
  'I\'ll be the best Valentine! 🌹 <em>I promise! 🥺</em>',
  'Okay last chance... 😭 <em>Choose wisely 💕</em>',
  'You\'ll miss all <em>the cuddles! 🫶</em>',
  'THE YES BUTTON IS RIGHT THERE 😭 <em>just click it!!</em>'
];

const subs = [
  'I promise it\'ll be the best decision ever ✨',
  'You know you want to say yes... 💕',
  'Think of all the chocolates and flowers! 🌹',
  'I\'ve been waiting for this moment... 🥺',
  'One tiny yes is all I need 💝',
  'Pinky promise it\'ll be magical ✨',
  'My whole heart is on the line here 💔',
  'The yes button is getting BIG for a reason 😭',
  'PLEASE. I am begging you. 🙏😭'
];

// ── No logic ──
function runNo() {
  if (noCount < MAX) noCount++;

  // Grow yes button
  yesBtn.style.fontSize = yesSizes[noCount] + 'rem';
  yesBtn.style.padding  = (12 + noCount * 3) + 'px ' + (44 + noCount * 10) + 'px';

  // Shrink no button
  noBtn.style.fontSize = noSizes[noCount] + 'rem';
  noBtn.style.padding  = noPads[noCount] + 'px ' + (noPads[noCount] * 2.2) + 'px';

  // Update message
  document.getElementById('mainTitle').innerHTML      = titles[noCount];
  document.getElementById('mainSub').textContent      = subs[noCount];
  document.getElementById('pleadingEmojis').textContent = pleadingSets[noCount];

  // Drift no button to a random spot on screen
  const btnW = noBtn.offsetWidth  || 80;
  const btnH = noBtn.offsetHeight || 40;
  const pad  = 16;
  const maxX = Math.max(pad, window.innerWidth  - btnW - pad);
  const maxY = Math.max(pad, window.innerHeight - btnH - pad);

  // Pick a spot that's not too close to current position
  let rx, ry, tries = 0;
  const curL = parseFloat(noBtn.style.left) || window.innerWidth / 2;
  const curT = parseFloat(noBtn.style.top)  || window.innerHeight / 2;
  do {
    rx = pad + Math.random() * maxX;
    ry = pad + Math.random() * maxY;
    tries++;
  } while (tries < 30 && Math.hypot(rx - curL, ry - curT) < 150);

  noBtn.style.left = rx + 'px';
  noBtn.style.top  = ry + 'px';
}

// Also flee on mouse enter (desktop) / touchstart (mobile)
noBtn.addEventListener('mouseenter', runNo);
noBtn.addEventListener('touchstart', function(e) {
  e.preventDefault();
  runNo();
}, { passive: false });

// ── Say Yes ──
function sayYes() {
  noBtn.style.display = 'none';

  // Confetti burst
  const colors = ['#ff6b9d','#ff4d6d','#ffb3c6','#c9184a','#ffd6e7','#ff85a1','#ffffff','#ffd700'];
  for (let i = 0; i < 90; i++) {
    const c = document.createElement('div');
    c.classList.add('cp');
    c.style.background    = colors[Math.floor(Math.random() * colors.length)];
    c.style.width         = (5 + Math.random() * 11) + 'px';
    c.style.height        = (5 + Math.random() * 11) + 'px';
    c.style.borderRadius  = Math.random() > .4 ? '50%' : '3px';
    c.style.left          = (15 + Math.random() * 70) + 'vw';
    c.style.top           = (15 + Math.random() * 70) + 'vh';
    const angle = Math.random() * Math.PI * 2;
    const dist  = 80 + Math.random() * 280;
    c.style.setProperty('--tx', Math.cos(angle) * dist + 'px');
    c.style.setProperty('--ty', Math.sin(angle) * dist + 'px');
    c.style.animationDelay = (Math.random() * .5) + 's';
    document.body.appendChild(c);
    setTimeout(() => c.remove(), 2200);
  }

  // Switch to yay screen
  document.getElementById('questionView').style.display = 'none';
  document.getElementById('yayScreen').style.display    = 'flex';
}
</script>
</body>
</html>
