<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Function Test</title>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <style>
    body { font-family: sans-serif; padding: 2rem; background: #fafaf8; max-width: 500px; margin: 0 auto; }
    button { width: 100%; padding: 14px; font-size: 15px; cursor: pointer; border: 1px solid #333; border-radius: 8px; background: #fff; margin-bottom: 12px; }
    button:hover { background: #f0f0f0; }
    #log { background: #111; color: #ccc; font-family: monospace; font-size: 13px; padding: 1rem; border-radius: 8px; white-space: pre-wrap; min-height: 200px; margin-top: 1rem; }
    .ok { color: #7dff7d; }
    .err { color: #ff7d7d; }
    .info { color: #7db8ff; }
  </style>
</head>
<body>
  <h2>Edge Function Test</h2>
  <p style="font-size:13px;color:#666;margin-bottom:1.5rem;">Upload this to GitHub, open it, sign in with Google first on the main site, then come back and click the buttons below.</p>

  <button onclick="checkSession()">Step 1 — Am I logged in?</button>
  <button onclick="pingFunction()">Step 2 — Can I reach the notify function?</button>
  <button onclick="sendTestEmail()">Step 3 — Send test email to ambikabanerjee17@gmail.com</button>

  <div id="log"></div>

<script>
  const SUPABASE_URL = 'https://dioxbtmvkonwgovpqdqx.supabase.co';
  const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRpb3hidG12a29ud2dvdnBxZHF4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ2Nzg2MzcsImV4cCI6MjA5MDI1NDYzN30.7ZlAtTqpKvXWUNlTRwN4bcAB9V87eTfHaB-vNMXZKr0';

  const sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  const logEl = document.getElementById('log');

  function log(msg, type) {
    const line = document.createElement('div');
    line.className = type || 'info';
    line.textContent = new Date().toLocaleTimeString() + '  ' + msg;
    logEl.appendChild(line);
  }

  // Step 1 — check session
  async function checkSession() {
    log('Checking session...', 'info');
    const { data: { session } } = await sb.auth.getSession();
    if (session?.user) {
      log('LOGGED IN as: ' + session.user.email, 'ok');
    } else {
      log('NOT LOGGED IN — go to your main site first, sign in with Google, then come back here', 'err');
    }
  }

  // Step 2 — ping the function
  async function pingFunction() {
    log('Calling notify function...', 'info');
    try {
      const { data, error } = await sb.functions.invoke('notify', {
        body: { type: 'ping' }
      });
      if (error) {
        log('ERROR: ' + JSON.stringify(error), 'err');
        if (JSON.stringify(error).includes('404')) {
          log('REASON: Function named "notify" not found in Supabase. Check spelling — must be exactly "notify"', 'err');
        } else if (JSON.stringify(error).includes('401') || JSON.stringify(error).includes('403')) {
          log('REASON: Not authorised — make sure you are logged in (run Step 1 first)', 'err');
        } else if (JSON.stringify(error).includes('networkerror') || JSON.stringify(error).includes('fetch')) {
          log('REASON: Network error — Edge Functions may not be enabled on your Supabase plan', 'err');
        }
      } else {
        log('Function reached! Response: ' + JSON.stringify(data), 'ok');
      }
    } catch(e) {
      log('EXCEPTION: ' + e.message, 'err');
    }
  }

  // Step 3 — send real test email
  async function sendTestEmail() {
    log('Sending test email...', 'info');
    try {
      const { data, error } = await sb.functions.invoke('notify', {
        body: {
          type: 'note',
          data: {
            fromName: 'Anuja',
            toName: 'Ambika',
            toEmail: 'ambikabanerjee17@gmail.com',
            message: 'Test email — if you see this, everything is working!'
          }
        }
      });
      if (error) {
        log('ERROR: ' + JSON.stringify(error), 'err');
      } else {
        log('Done! Response: ' + JSON.stringify(data), 'ok');
        log('Now check ambikabanerjee17@gmail.com inbox (and spam folder)', 'ok');
        log('Also check Resend → Logs to see if the send was attempted', 'info');
      }
    } catch(e) {
      log('EXCEPTION: ' + e.message, 'err');
    }
  }

  // auto check session on load
  checkSession();
</script>
</body>
</html>
